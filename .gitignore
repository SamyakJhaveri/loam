# Local machine-specific config (generated from config/paths.json.template by setup script)
config/paths.json
# macOS
.DS_Store
.AppleDouble
.LSOverride
# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
.env
.pytest_cache/
# IDE
.idea/
.vscode/
*.swp
*.swo
# Byte-compiled / temp
*.log
*.tmp
# Claude Code agent worktrees (temporary, auto-cleaned)
.claude/worktrees/
# Post-session validation sentinel (written by /validate, never committed)
.validation_passed
# Codex review sentinel (written/cleaned by sentinel-cleanup.sh hook, never committed)
.codex_review_done
# Bash audit log (written by bash-audit-log.sh hook, grows unbounded)
.claude/audit.log
# Machine-local paths (generated by setup_claude_for_sam.sh)
.claude/.local-paths
# User-local settings (generated from .claude/settings.local.json.template)
# Glob form covers both the repo-root symlink path and the real seed/.claude/ target.
**/.claude/settings.local.json
# Codex CLI local state; repo policy config is intentionally committed.
.codex/
!.codex/
!.codex/config.toml
# File ownership tracking (session-ephemeral, written by file-ownership.sh hook)
.file-owners.json
# Build artifacts
*.o
*.out
*.a
*.so
*.d

# ANL credentials — never commit
*.pem
*_key*
*_secret*
*credentials*
.codegraphcontext/

# Personal reference docs — not part of the template (audit Session C)
internal_docs/
# Brainstorm / scratch outputs from Cowork sessions
outputs/
# Image pollution (Mac screenshots / pasted images)
IMG_*
# Superpowers brainstorm/scratch outputs
.superpowers/
# MCP server config (may contain env var references to API keys)
.mcp.json
# Generated course output from codebase-to-course skill testing
*-course/
# Ad-hoc conversation exports / archives
*.zip
2026-*
!docs/plans/2026-06-01-codex-diagram-rerun-brief.md

# Copyrighted Yoshida reference scans — never commit (style refs only, local-only)
yoshida_hiroshi/

# Track-B proof renders (large 4K candidates) — judge locally, commit chosen winners deliberately.
# Scoped to loam-hero-*.png so committed *.drawio.png diagrams are unaffected.
docs/diagrams/loam-hero-*.png
docs/diagrams/loam-hero-*.qa.yaml

