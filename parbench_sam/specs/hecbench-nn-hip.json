{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "nn",
    "parallel_api": "hip",
    "unique_id": "hecbench-nn-hip",
    "source_suite": "hecbench"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/zjin-lcf/HeCBench",
      "commit": "archive-download",
      "branch": "master"
    },
    "repo_root": "../ParBench/downloads/HeCBench_extracted/HeCBench-master",
    "source_path": "src/nn-hip",
    "license": "MIT"
  },
  "files": {
    "prompt_payload": [
      "nearestNeighbor.cu",
      "nearestNeighbor.h"
    ],
    "support_files": [
      "Makefile",
      "Makefile.hipcl",
      "CMakeLists.txt",
      "utils.cu",
      "utils.h",
      "filelist.txt"
    ],
    "verification_only": []
  },
  "implementation": {
    "api": "hip",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++17"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "ROCm >= 5.0",
          "hipcc"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/nn-hip",
    "commands": {
      "configure": null,
      "build": "make",
      "clean": "make clean"
    },
    "variables": null,
    "outputs": {
      "executable": "main"
    }
  },
  "run": {
    "executable": "./main",
    "default_arguments": [
      "filelist.txt",
      "-r",
      "5",
      "-lat",
      "30",
      "-lng",
      "90",
      "-i",
      "10"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "filelist.txt",
          "-r",
          "5",
          "-lat",
          "30",
          "-lng",
          "90",
          "-i",
          "1"
        ],
        "description": "Single-iteration run for quick correctness validation",
        "input_files": [
          "filelist.txt"
        ],
        "expected_results": null
      },
      "performance": {
        "arguments": [
          "filelist.txt",
          "-r",
          "5",
          "-lat",
          "30",
          "-lng",
          "90",
          "-i",
          "10000",
          "-t"
        ],
        "description": "10000-iteration run for performance measurement with timing output",
        "input_files": [
          "filelist.txt"
        ],
        "expected_results": null
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Check for successful execution (no PASS/FAIL output for this kernel)"
      }
    ],
    "floating_point": null
  },
  "performance": {
    "metrics": [
      {
        "name": "kernel_time",
        "extraction": {
          "type": "regex",
          "pattern": "Average kernel execution time:\\s+([\\d.]+)\\s+\\(us\\)",
          "capture_group": 1
        },
        "unit": "us"
      },
      {
        "name": "offloading_time",
        "extraction": {
          "type": "regex",
          "pattern": "Device offloading time\\s+([\\d.]+)\\s+\\(s\\)",
          "capture_group": 1
        },
        "unit": "s"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "gpu",
    "requirements": {
      "gpu": {
        "vendor": "AMD",
        "min_memory_gb": 2
      }
    },
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
      "gpu": {
        "model": "NVIDIA GeForce RTX 4070",
        "architecture": "Ada Lovelace",
        "compute_capability": "sm_89",
        "vram_gb": 12,
        "memory_bandwidth_gbps": 504,
        "cuda_cores": 5888
      },
      "cpu": {
        "model": "AMD Ryzen 9 7900X",
        "cores": 12,
        "threads": 24,
        "base_clock_ghz": 4.7
      },
      "software": {
        "os": "Ubuntu 22.04 LTS",
        "cuda_toolkit": "12.x",
        "gcc": "11+",
        "driver": "525.x+"
      }
    }
  },
  "baseline_results": null,
  "metadata": {
    "description": "Nearest neighbor search: computes Euclidean distances from a query point (lat,lng) to every record in a geographic database and finds the top-N closest.",
    "domain": "nearest neighbor search",
    "complexity": "O(n)",
    "tags": [
      "nearest-neighbor",
      "euclidean-distance",
      "geographic",
      "search"
    ],
    "multi_file": true
  }
}
