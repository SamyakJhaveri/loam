{
    "env": {
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
    },
    "permissions": {
        "allow": [
            "Bash(date:*)",
            "Bash(echo:*)",
            "Bash(cat:*)",
            "Bash(ls:*)",
            "Bash(mkdir:*)",
            "Bash(wc:*)",
            "Bash(head:*)",
            "Bash(tail:*)",
            "Bash(sort:*)",
            "Bash(grep:*)",
            "Bash(tr:*)",
            "Bash(git add:*)",
            "Bash(git commit:*)",
            "Bash(git status:*)",
            "Bash(git log:*)",
            "Bash(git diff:*)",
            "Bash(git tag:*)"
        ],
        "deny": [
            "Bash(rm -rf:*)",
            "Bash(rm -fr:*)",
            "Bash(git push --force:*)",
            "Bash(git reset --hard:*)",
            "Read(.env*)",
            "Edit(.env*)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'rm -rf|rm -fr'; then echo 'BLOCKED: rm -rf not allowed' >&2 && exit 2; fi",
                        "timeout": 15
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/pre-commit-gate.sh",
                        "timeout": 10
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/bash-audit-log.sh",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/protect-cuda-omp-results.sh",
                        "timeout": 10
                    }
                ]
            },
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/protect-benchmark-sources.sh",
                        "timeout": 10
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/result-immutability.sh",
                        "timeout": 10
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/post-compact-recovery.sh",
                        "timeout": 10
                    }
                ]
            },
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "FILE=$(echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('file_path',''))\" 2>/dev/null); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -qE '\\.py$'; then python3 -m ruff check --fix \"$FILE\" 2>/dev/null || true; fi"
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/post-edit-test.sh",
                        "timeout": 35
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/sentinel-cleanup.sh",
                        "timeout": 5
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/context-budget.sh",
                        "timeout": 5
                    }
                ]
            }
        ]
    },
    "enabledPlugins": {}
}