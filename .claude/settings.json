{
    "env": {
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
    },
    "permissions": {
        "deny": [
            "Bash(rm -rf:*)",
            "Bash(rm -fr:*)",
            "Bash(git push --force:*)",
            "Bash(git reset --hard:*)",
            "Read(.env*)",
            "Edit(.env*)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'rm -rf|rm -fr'; then echo 'BLOCKED: rm -rf not allowed' >&2 && exit 2; fi",
                        "timeout": 15
                    },
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/pre-commit-gate.sh",
                        "timeout": 10
                    },
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/bash-audit-log.sh",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/protect-cuda-omp-results.sh",
                        "timeout": 10
                    }
                ]
            },
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/protect-benchmark-sources.sh",
                        "timeout": 10
                    },
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/result-immutability.sh",
                        "timeout": 10
                    },
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/file-ownership.sh",
                        "timeout": 10
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/post-compact-recovery.sh",
                        "timeout": 10
                    }
                ]
            },
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "FILE=$(echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('file_path',''))\" 2>/dev/null); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -qE '\\.py$'; then python3 -m ruff check --fix \"$FILE\" 2>/dev/null || true; fi"
                    },
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/post-edit-test.sh",
                        "timeout": 35
                    },
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/sentinel-cleanup.sh",
                        "timeout": 5
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/context-budget.sh",
                        "timeout": 5
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "/home/samyak/Desktop/parbench_sam/.claude/hooks/dream-hook.sh",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": "echo '\\n=== PRE-STOP CHECKLIST ===' >&2; echo '(1) /validate run (waves_passed=4)?' >&2; echo '(2) /review run on diff?' >&2; echo '(3) eval batch → analyze_eval.py complete?' >&2; echo '(4) dashboard-refresher after eval/spec changes?' >&2; echo '(5) .validation_passed sentinel before commit?' >&2; echo '(6) All tasks complete — no partial work?' >&2; echo '(7) Evidence for every claim — actual output?' >&2; echo '(8) known-issues.md / CLAUDE.md updated?' >&2; echo '=========================' >&2; exit 0",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": "notify-send 'Claude Code' 'Task completed' 2>/dev/null || true"
                    }
                ]
            }
        ]
    },
    "enabledPlugins": {
        "superpowers@superpowers-dev": true
    }
}