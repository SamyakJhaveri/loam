{
    "spec_version": "1.0.0",
    "identity": {
        "kernel_name": "chacha20",
        "parallel_api": "omp",
        "unique_id": "hecbench-chacha20-omp",
        "source_suite": "hecbench"
    },
    "provenance": {
        "repository": {
            "url": "https://github.com/zjin-lcf/HeCBench",
            "commit": "archive-download",
            "branch": "master"
        },
        "repo_root": "HeCBench-master/",
        "source_path": "src/chacha20-omp",
        "license": "MIT"
    },
    "files": {
        "prompt_payload": [
            "main.cpp",
            "chacha20.h"
        ],
        "support_files": [
            "Makefile",
            "Makefile.aomp",
            "Makefile.nvc",
            "CMakeLists.txt",
            "LICENSE"
        ],
        "verification_only": []
    },
    "implementation": {
        "api": "omp",
        "api_version": null,
        "language": "C++",
        "language_standard": "C++17"
    },
    "build": {
        "environment": {
            "preferred": "system",
            "conda": null,
            "system": {
                "dependencies": [
                    "GCC >= 9.0 with OpenMP support"
                ]
            }
        },
        "build_system": "make",
        "working_directory": "src/chacha20-omp",
        "commands": {
            "configure": null,
            "build": "make -f Makefile.aomp CC=g++ DEVICE=cpu",
            "clean": "make -f Makefile.aomp clean"
        },
        "variables": null,
        "outputs": {
            "executable": "main"
        }
    },
    "run": {
        "executable": "./main",
        "default_arguments": [
            "100000"
        ],
        "timeout_seconds": 300,
        "environment_variables": {
            "OMP_NUM_THREADS": "1"
        },
        "input_configurations": {
            "correctness": {
                "arguments": [
                    "1"
                ],
                "description": "Single-iteration run for correctness validation against RFC test vector",
                "input_files": [],
                "expected_results": {
                    "stdout_pattern": "PASS"
                }
            },
            "performance": {
                "arguments": [
                    "100000"
                ],
                "description": "100000-iteration run for performance measurement",
                "input_files": [],
                "expected_results": {
                    "stdout_pattern": "PASS"
                }
            }
        }
    },
    "verification": {
        "method": "self_checking",
        "strategies": [
            {
                "type": "stdout_pattern",
                "pattern": "PASS",
                "description": "memcmp of GPU keystream vs RFC 7539 test vector"
            },
            {
                "type": "exit_code",
                "expected": 0,
                "description": "Process exits cleanly"
            }
        ],
        "floating_point": null
    },
    "performance": {
        "metrics": [
            {
                "name": "kernel_time",
                "extraction": {
                    "type": "regex",
                    "pattern": "Average execution time of kernels:\\s+([\\d.eE+-]+)\\s+\\(us\\)",
                    "capture_group": 1
                },
                "unit": "us"
            }
        ],
        "warmup_runs": 1,
        "measurement_runs": 5
    },
    "hardware": {
        "target": "cpu",
        "requirements": null,
        "reference_platform": {
            "platform_id": "rtx4070-r9-7900x",
            "gpu": {
                "model": "NVIDIA GeForce RTX 4070",
                "architecture": "Ada Lovelace",
                "compute_capability": "sm_89",
                "vram_gb": 12,
                "memory_bandwidth_gbps": 504,
                "cuda_cores": 5888
            },
            "cpu": {
                "model": "AMD Ryzen 9 7900X",
                "cores": 12,
                "threads": 24,
                "base_clock_ghz": 4.7
            },
            "software": {
                "os": "Ubuntu 22.04 LTS",
                "cuda_toolkit": "12.x",
                "gcc": "11+",
                "driver": "525.x+"
            }
        }
    },
    "baseline_results": null,
    "metadata": {
        "description": "ChaCha20 stream cipher keystream generation on GPU. Generates keystreams in parallel and verifies against known RFC 7539 test vectors via memcmp.",
        "domain": "cryptography",
        "complexity": "O(n \u00d7 rounds)",
        "tags": [
            "chacha20",
            "stream-cipher",
            "encryption",
            "cryptography"
        ],
        "multi_file": false
    }
}