    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "1",
          "1",
          "33554432"
        ],
        "description": "Single iteration for correctness; verifies CRC-64 checksums match CPU reference",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      },
      "performance": {
        "arguments": [
          "10",
          "5",
          "33554432"
        ],
        "description": "10 iterations, 5 passes for performance measurement",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "stdout_pattern",
        "pattern": "(?i)pass",
        "description": "CRC-64 checksum matches CPU reference (case-insensitive)"
      },
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly"
      }
    ],
    "floating_point": null
  },
  "performance": {
    "metrics": [
      {
        "name": "throughput",
        "extraction": {
          "type": "regex",
          "pattern": "([\\d.eE+-]+)\\s+MB/s",
          "capture_group": 1
