{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "lavamd",
    "parallel_api": "cuda",
    "unique_id": "rodinia-lavamd-cuda",
    "source_suite": "rodinia"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/yuhc/gpu-rodinia",
      "commit": "9c10d3ea16ddba2ba057cc3951a9efc4c2cc18a4",
      "branch": "master"
    },
    "repo_root": "rodinia/rodinia-src",
    "source_path": "cuda/lavaMD",
    "license": "NCSA/Illinois Open Source License"
  },
  "files": {
    "prompt_payload": [
      "kernel/kernel_gpu_cuda.cu",
      "kernel/kernel_gpu_cuda_wrapper.cu",
      "util/device/device.cu"
    ],
    "support_files": [
      "main.c",
      "util/num/num.c",
      "util/timer/timer.c",
      "kernel/kernel_gpu_cuda_wrapper.h",
      "main.h",
      "util/device/device.h",
      "util/num/num.h",
      "util/timer/timer.h",
      "makefile"
    ],
    "verification_only": []
  },
  "implementation": {
    "api": "cuda",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++14"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "cuda-toolkit>=11.0",
          "gcc>=9.0"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "cuda/lavaMD",
    "commands": {
      "configure": null,
      "build": "make CUDA_DIR=/usr/local/cuda",
      "clean": "make clean"
    },
    "variables": {
      "CUDA_DIR": {
        "description": "Path to CUDA toolkit installation",
        "default": "/usr/local/cuda",
        "detection": "dirname $(dirname $(which nvcc))"
      }
    },
    "outputs": {
      "executable": "./lavaMD"
    }
  },
  "run": {
    "executable": "./lavaMD",
    "default_arguments": [
      "-cores",
      "1",
      "-boxes",
      "10"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "-cores",
          "1",
          "-boxes",
          "10"
        ],
        "description": "Small input for correctness verification of lavaMD (CUDA)",
        "input_files": [],
        "expected_results": null
      },
      "performance": {
        "arguments": [
          "-cores",
          "1",
          "-boxes",
          "30"
        ],
        "description": "Large input for performance measurement of lavaMD (CUDA)",
        "input_files": [],
        "expected_results": null
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly"
      }
    ],
    "floating_point": null
  },
  "performance": null,
  "hardware": {
    "target": "gpu",
    "requirements": {
      "gpu": {
        "vendor": "NVIDIA",
        "min_compute_capability": "sm_60",
        "min_memory_gb": 4
      }
    },
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
      "gpu": {
        "model": "NVIDIA GeForce RTX 4070",
        "architecture": "Ada Lovelace",
        "compute_capability": "sm_89",
        "vram_gb": 12,
        "memory_bandwidth_gbps": 504,
        "cuda_cores": 5888
      },
      "cpu": {
        "model": "AMD Ryzen 9 7900X",
        "cores": 12,
        "threads": 24,
        "base_clock_ghz": 4.7
      },
      "software": {
        "os": "Ubuntu 22.04 LTS",
        "cuda_toolkit": "12.x",
        "gcc": "11+",
        "driver": "525.x+"
      }
    }
  },
  "baseline_results": null,
  "metadata": {
    "description": "Molecular dynamics simulation using Lennard-Jones potential on GPU",
    "domain": "molecular dynamics",
    "complexity": "molecular dynamics (Lennard-Jones potential)",
    "tags": [
      "cuda",
      "lavaMD",
      "lennard-jones",
      "molecular-dynamics",
      "rodinia",
      "simulation"
    ],
    "multi_file": true
  }
}
