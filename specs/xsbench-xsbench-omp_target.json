{
    "spec_version": "1.0.0",
    "identity": {
        "kernel_name": "xsbench",
        "parallel_api": "omp_target",
        "unique_id": "xsbench-xsbench-omp_target",
        "source_suite": "xsbench"
    },
    "provenance": {
        "repository": {
            "url": "https://github.com/ANL-CESAR/XSBench",
            "commit": "ba08e5221af6106252b866e50ea123c69d31a4e2",
            "branch": "master"
        },
        "repo_root": "xsbench/xsbench-src",
        "source_path": "openmp-offload",
        "license": "MIT"
    },
    "files": {
        "prompt_payload": [
            "Main.c",
            "io.c",
            "Simulation.c",
            "GridInit.c",
            "XSutils.c",
            "Materials.c"
        ],
        "support_files": [
            "Makefile",
            "XSbench_header.h"
        ],
        "verification_only": [],
        "translation_targets": [
            "Main.c",
            "io.c",
            "Simulation.c",
            "GridInit.c",
            "XSutils.c",
            "Materials.c"
        ]
    },
    "implementation": {
        "api": "omp_target",
        "api_version": null,
        "language": "C",
        "language_standard": "C11"
    },
    "build": {
        "environment": {
            "preferred": "system",
            "conda": null,
            "system": {
                "dependencies": [
                    "nvidia-hpc-sdk (nvc with OpenMP target offload)"
                ]
            }
        },
        "build_system": "make",
        "working_directory": "openmp-offload",
        "commands": {
            "configure": null,
            "build": "make COMPILER=nvidia CC=/opt/nvidia/hpc_sdk/Linux_x86_64/24.3/compilers/bin/nvc CFLAGS='-std=gnu99 -Wall -mp=gpu -Minfo=mp -gpu=cc89 -O3'",
            "clean": "make clean"
        },
        "variables": null,
        "outputs": {
            "executable": "./XSBench"
        }
    },
    "run": {
        "executable": "./XSBench",
        "default_arguments": [
            "-m",
            "event",
            "-s",
            "small"
        ],
        "timeout_seconds": 300,
        "environment_variables": null,
        "input_configurations": {
            "correctness": {
                "arguments": [
                    "-m",
                    "event",
                    "-s",
                    "small"
                ],
                "description": "Small event-based input for correctness verification of xsbench (OpenMP target offload)",
                "input_files": [],
                "expected_results": {
                    "stdout_pattern": "Verification checksum: \\d+ \\(Valid\\)"
                }
            },
            "performance": {
                "arguments": [
                    "-m",
                    "event",
                    "-s",
                    "large"
                ],
                "description": "Large event-based input for performance measurement of xsbench (OpenMP target offload)",
                "input_files": [],
                "expected_results": {
                    "stdout_pattern": "Verification checksum: \\d+ \\(Valid\\)"
                }
            }
        }
    },
    "verification": {
        "method": "self_checking",
        "strategies": [
            {
                "type": "exit_code",
                "expected": 0,
                "description": "Process exits with code 0 on valid checksum, 1 on invalid"
            },
            {
                "type": "stdout_pattern",
                "pattern": "Verification checksum: \\d+ \\(Valid\\)",
                "description": "XSBench self-verification reports valid checksum"
            }
        ],
        "floating_point": null
    },
    "performance": null,
    "hardware": {
        "target": "gpu",
        "requirements": {
            "gpu": {
                "vendor": "NVIDIA",
                "min_compute_capability": "sm_60",
                "min_memory_gb": 4
            }
        },
        "reference_platform": {
            "platform_id": "rtx4070-r9-7900x",
            "gpu": {
                "model": "NVIDIA GeForce RTX 4070",
                "architecture": "Ada Lovelace",
                "compute_capability": "sm_89",
                "vram_gb": 12,
                "memory_bandwidth_gbps": 504,
                "cuda_cores": 5888
            },
            "cpu": {
                "model": "AMD Ryzen 9 7900X",
                "cores": 12,
                "threads": 24,
                "base_clock_ghz": 4.7
            },
            "software": {
                "os": "Ubuntu 22.04 LTS",
                "cuda_toolkit": "12.x",
                "gcc": "11+",
                "driver": "525.x+"
            }
        }
    },
    "baseline_results": null,
    "metadata": {
        "description": "Monte Carlo neutron cross-section lookup (XSBench)",
        "domain": "nuclear physics",
        "complexity": "Monte Carlo cross-section lookup with energy grid search",
        "tags": [
            "omp_target",
            "monte-carlo",
            "nuclear",
            "physics",
            "xsbench"
        ],
        "multi_file": true,
        "translation_complexity": null
    }
}
