  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "NVIDIA HPC SDK >= 24.0 (nvc++)",
          "OpenMP target offload support"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/iso2dfd-omp",
    "commands": {
      "configure": null,
      "build": "make -f Makefile.nvc SM=cc89 CC=/opt/nvidia/hpc_sdk/Linux_x86_64/24.3/compilers/bin/nvc++",
      "clean": "make -f Makefile.nvc clean"
    },
    "variables": null,
    "outputs": {
      "executable": "main"
    }
  },
  "run": {
    "executable": "./main",
    "default_arguments": [
      "1000",
      "1000",
      "100"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "1000",
          "1000",
          "100"
        ],
        "description": "2D finite-difference wave propagation with 1000x1000 grid, 100 iterations; GPU vs CPU within_epsilon check",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      },
      "performance": {
        "arguments": [
          "1000",
          "1000",
          "1000"
        ],
        "description": "1000 iterations for timing measurement",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "stdout_pattern",
        "pattern": "PASS",
        "description": "GPU wavefield compared to CPU reference via within_epsilon (tolerance 0.1); prints PASS or FAIL"
      },
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits with 0 on PASS, 1 on FAIL"
      }
    ],
    "floating_point": null
  },
  "performance": {
    "metrics": [
      {
        "name": "total_kernel_time",
        "extraction": {
          "type": "regex",
          "pattern": "Total kernel execution time\\s+([\\d.eE+-]+)\\s+\\(ms\\)",
          "capture_group": 1
        },
        "unit": "ms"
      },
      {
        "name": "avg_kernel_time",
        "extraction": {
          "type": "regex",
          "pattern": "Average kernel execution time\\s+([\\d.eE+-]+)\\s+\\(us\\)",
          "capture_group": 1
        },
        "unit": "us"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "gpu",
    "requirements": {
      "gpu": {
        "vendor": "NVIDIA",
        "min_compute_capability": "sm_60",
        "min_memory_gb": 2
