          "GCC >= 9.0"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/fpc-cuda",
    "commands": {
      "configure": null,
      "build": "make ARCH=sm_89",
      "clean": "make clean"
    },
    "variables": null,
    "outputs": {
      "executable": "main"
    }
  },
  "run": {
    "executable": "./main",
    "default_arguments": [
      "256",
      "100"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "256",
          "1"
        ],
        "description": "Single iteration FPC compress/decompress; verifies round-trip correctness",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      },
      "performance": {
        "arguments": [
          "256",
          "100"
        ],
        "description": "100-iteration run for performance measurement",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "stdout_pattern",
        "pattern": "PASS",
        "description": "Round-trip compress/decompress verification; prints PASS or FAIL"
      },
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly"
      }
    ],
    "floating_point": null
  },
  "performance": {
    "metrics": [
      {
        "name": "kernel_time",
        "extraction": {
          "type": "regex",
          "pattern": "Average kernel execution time\\s+([\\d.eE+-]+)\\s+\\(us\\)",
          "capture_group": 1
        },
        "unit": "us"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "gpu",
    "requirements": {
