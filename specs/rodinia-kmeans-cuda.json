{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "kmeans",
    "parallel_api": "cuda",
    "unique_id": "rodinia-kmeans-cuda",
    "source_suite": "rodinia"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/yuhc/gpu-rodinia",
      "commit": "9c10d3ea16ddba2ba057cc3951a9efc4c2cc18a4",
      "branch": "master"
    },
    "repo_root": "rodinia/rodinia-src",
    "source_path": "cuda/kmeans",
    "license": "NCSA/Illinois Open Source License"
  },
  "files": {
    "prompt_payload": [
      "kmeans_cuda.cu",
      "kmeans_cuda_kernel.cu"
    ],
    "support_files": [
      "cluster.c",
      "getopt.c",
      "kmeans.c",
      "kmeans_clustering.c",
      "rmse.c",
      "getopt.h",
      "kmeans.h",
      "unistd.h",
      "Makefile"
    ],
    "verification_only": []
  },
  "implementation": {
    "api": "cuda",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++14"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "cuda-toolkit>=11.0",
          "gcc>=9.0"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "cuda/kmeans",
    "commands": {
      "configure": null,
      "build": "make CUDA_DIR=/usr/local/cuda",
      "clean": "make clean"
    },
    "variables": {
      "CUDA_DIR": {
        "description": "Path to CUDA toolkit installation",
        "default": "/usr/local/cuda",
        "detection": "dirname $(dirname $(which nvcc))"
      }
    },
    "outputs": {
      "executable": "./kmeans"
    }
  },
  "run": {
    "executable": "./kmeans",
    "default_arguments": [
      "-i",
      "../../data/kmeans/kdd_cup"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "-i",
          "../../data/kmeans/kdd_cup"
        ],
        "description": "Small input for correctness verification of kmeans (CUDA)",
        "input_files": [
          "../../data/kmeans/kdd_cup"
        ],
        "expected_results": null
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly"
      },
      {
        "type": "numeric_comparison",
        "tolerance": 0.001,
        "tolerance_type": "relative",
        "description": "Numerical results within tolerance"
      },
      {
        "type": "stdout_pattern",
        "pattern": "(?i)(pass|correct|match|verified)",
        "description": "Results match reference"
      }
    ],
    "floating_point": null
  },
  "performance": null,
  "hardware": {
    "target": "gpu",
    "requirements": {
      "gpu": {
        "vendor": "NVIDIA",
        "min_compute_capability": "sm_60",
        "min_memory_gb": 4
      }
    },
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
      "gpu": {
        "model": "NVIDIA GeForce RTX 4070",
        "architecture": "Ada Lovelace",
        "compute_capability": "sm_89",
        "vram_gb": 12,
        "memory_bandwidth_gbps": 504,
        "cuda_cores": 5888
      },
      "cpu": {
        "model": "AMD Ryzen 9 7900X",
        "cores": 12,
        "threads": 24,
        "base_clock_ghz": 4.7
      },
      "software": {
        "os": "Ubuntu 22.04 LTS",
        "cuda_toolkit": "12.x",
        "gcc": "11+",
        "driver": "525.x+"
      }
    }
  },
  "baseline_results": null,
  "metadata": {
    "description": "K-means clustering on GPU",
    "domain": "machine learning",
    "complexity": "k-means clustering",
    "tags": [
      "clustering",
      "cuda",
      "k-means",
      "kmeans",
      "machine-learning",
      "rodinia"
    ],
    "multi_file": true
  }
}
