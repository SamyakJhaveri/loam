        "source_suite": "hecbench"
    },
    "provenance": {
        "repository": {
            "url": "https://github.com/zjin-lcf/HeCBench",
            "commit": "archive-download",
            "branch": "master"
        },
        "repo_root": "HeCBench-master/",
        "source_path": "src/lulesh-omp",
        "license": "MIT"
    },
    "files": {
        "prompt_payload": [
            "lulesh.cc",
            "lulesh-init.cc",
            "lulesh-util.cc",
            "lulesh-viz.cc",
            "lulesh.h"
        ],
        "support_files": [
            "Makefile",
            "Makefile.aomp",
            "Makefile.nvc",
            "CMakeLists.txt"
        ],
        "verification_only": []
    },
    "implementation": {
        "api": "omp",
        "api_version": null,
        "language": "C++",
        "language_standard": "C++17"
    },
    "build": {
        "environment": {
            "preferred": "system",
            "conda": null,
            "system": {
                "dependencies": [
                    "GCC >= 9.0 with OpenMP support"
                ]
            }
        },
        "build_system": "make",
        "working_directory": "src/lulesh-omp",
        "commands": {
            "configure": null,
            "build": "make -f Makefile.aomp CC=g++ DEVICE=cpu",
            "clean": "make -f Makefile.aomp clean"
        },
        "variables": null,
        "outputs": {
            "executable": "lulesh"
        }
    },
    "run": {
        "executable": "./lulesh",
        "default_arguments": [
            "-i",
            "100",
            "-s",
            "128",
            "-r",
            "11",
            "-b",
            "1",
            "-c",
            "1"
        ],
        "timeout_seconds": 600,
        "environment_variables": null,
        "input_configurations": {
            "correctness": {
                "arguments": [
                    "-i",
                    "100",
                    "-s",
                    "45",
                    "-r",
                    "11",
                    "-b",
                    "1",
                    "-c",
                    "1"
                ],
                "description": "Small mesh (45^3 elements), 100 iterations; verify via TotalAbsDiff metric",
                "input_files": [],
                "expected_results": null
            },
            "performance": {
                "arguments": [
                    "-i",
                    "100",
                    "-s",
                    "128",
                    "-r",
                    "11",
                    "-b",
                    "1",
                    "-c",
                    "1"
                ],
                "description": "Large mesh (128^3 elements), 100 iterations for timing",
                "input_files": [],
                "expected_results": null
            }
        }
    },
    "verification": {
        "method": "self_checking",
        "strategies": [
            {
                "type": "stdout_pattern",
                "pattern": "TotalAbsDiff\\s*=\\s*[\\d.eE+-]+",
                "description": "LULESH outputs TotalAbsDiff metric; small values indicate correct simulation"
            },
            {
                "type": "exit_code",
                "expected": 0,
                "description": "Process exits cleanly"
            }
        ],
        "floating_point": {
            "tolerance": 1e-06,
            "tolerance_type": "absolute",
            "note": "TotalAbsDiff should be near zero for correct Sedov blast simulation"
        }
    },
    "performance": {
        "metrics": [
            {
                "name": "elapsed_time",
                "extraction": {
                    "type": "regex",
                    "pattern": "Elapsed time\\s+=\\s+([\\d.eE+-]+)\\s+\\(s\\)",
                    "capture_group": 1
                },
                "unit": "s"
            },
            {
                "name": "grind_time",
                "extraction": {
                    "type": "regex",
                    "pattern": "Grind time \\(us/z/c\\)\\s+=\\s+([\\d.eE+-]+)",
                    "capture_group": 1
                },
                "unit": "us/z/c"
            }
        ],
        "warmup_runs": 0,
        "measurement_runs": 3
    },
    "hardware": {
        "target": "cpu",
        "requirements": null,
        "reference_platform": {
            "platform_id": "rtx4070-r9-7900x",
            "gpu": {
                "model": "NVIDIA GeForce RTX 4070",
                "architecture": "Ada Lovelace",
                "compute_capability": "sm_89",
                "vram_gb": 12,
                "memory_bandwidth_gbps": 504,
                "cuda_cores": 5888
            },
            "cpu": {
                "model": "AMD Ryzen 9 7900X",
                "cores": 12,
                "threads": 24,
                "base_clock_ghz": 4.7
            },
            "software": {
                "os": "Ubuntu 22.04 LTS",
                "cuda_toolkit": "12.x",
                "gcc": "11+",
                "driver": "525.x+"
            }
        }
    },
