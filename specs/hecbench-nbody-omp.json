{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "nbody",
    "parallel_api": "omp",
    "unique_id": "hecbench-nbody-omp",
    "source_suite": "hecbench"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/zjin-lcf/HeCBench",
      "commit": "archive-download",
      "branch": "master"
    },
    "repo_root": "HeCBench-master/",
    "source_path": "src/nbody-omp",
    "license": "MIT"
  },
  "files": {
    "prompt_payload": [
      "GSimulation.cpp",
      "main.cpp"
    ],
    "support_files": [
      "Makefile",
      "Makefile.aomp",
      "Makefile.nvc",
      "CMakeLists.txt",
      "GSimulation.hpp",
      "Particle.hpp",
      "type.hpp",
      "License.txt"
    ],
    "verification_only": []
  },
  "implementation": {
    "api": "omp",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++17"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "GCC >= 9.0 with OpenMP support"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/nbody-omp",
    "commands": {
      "configure": null,
      "build": "make -f Makefile.aomp CC=g++ DEVICE=cpu",
      "clean": "make -f Makefile.aomp clean"
    },
    "variables": null,
    "outputs": {
      "executable": "main"
    }
  },
  "run": {
    "executable": "./main",
    "default_arguments": [
      "16000",
      "10"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "16000",
          "10"
        ],
        "description": "16000 particles, 10 steps; verifies kinetic energy against CPU reference",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      },
      "performance": {
        "arguments": [
          "16000",
          "10"
        ],
        "description": "16000 particles, 10 steps for performance measurement",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "stdout_pattern",
        "pattern": "PASS",
        "description": "Kinetic energy comparison: |GPU - CPU| < 1e-3"
      },
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly"
      }
    ],
    "floating_point": {
      "tolerance": 0.001,
      "tolerance_type": "absolute",
      "note": "Kinetic energy comparison between GPU and CPU reference"
    }
  },
  "performance": {
    "metrics": [
      {
        "name": "total_time",
        "extraction": {
          "type": "regex",
          "pattern": "# Total Time \\(s\\)\\s*:\\s*([\\d.eE+-]+)",
          "capture_group": 1
        },
        "unit": "s"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "cpu",
    "requirements": null,
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
      "gpu": {
        "model": "NVIDIA GeForce RTX 4070",
        "architecture": "Ada Lovelace",
        "compute_capability": "sm_89",
        "vram_gb": 12,
        "memory_bandwidth_gbps": 504,
        "cuda_cores": 5888
      },
      "cpu": {
        "model": "AMD Ryzen 9 7900X",
        "cores": 12,
        "threads": 24,
        "base_clock_ghz": 4.7
      },
      "software": {
        "os": "Ubuntu 22.04 LTS",
        "cuda_toolkit": "12.x",
        "gcc": "11+",
        "driver": "525.x+"
      }
    }
  },
  "baseline_results": null,
  "metadata": {
    "description": "Gravitational N-body simulation computing all-pairs particle interactions. GPU kernels accelerate force computation, position/velocity updates, and kinetic energy accumulation. Verified against CPU reference.",
    "domain": "physics simulation",
    "complexity": "O(n^2 \u00d7 steps)",
    "tags": [
      "n-body",
      "gravity",
      "particle-simulation",
      "physics",
      "all-pairs"
    ],
    "multi_file": true
  }
}
