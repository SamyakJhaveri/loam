{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "page-rank",
    "parallel_api": "omp_target",
    "unique_id": "hecbench-page-rank-omp_target",
    "source_suite": "hecbench"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/zjin-lcf/HeCBench",
      "commit": "22785cdd708de5dca56525a277b31fe119171fd1",
      "branch": "master"
    },
    "repo_root": "HeCBench-master/",
    "source_path": "src/page-rank-omp",
    "license": "MIT"
  },
  "files": {
    "prompt_payload": [
      "main.cpp"
    ],
    "support_files": [
      "Makefile",
      "Makefile.nvc",
      "Makefile.aomp",
      "CMakeLists.txt"
    ],
    "verification_only": [],
    "translation_targets": [
      "main.cpp"
    ]
  },
  "implementation": {
    "api": "omp_target",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++14"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "nvidia-hpc-sdk (nvc++ with OpenMP target offload)"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/page-rank-omp",
    "commands": {
      "configure": null,
      "build": "make -f Makefile.nvc SM=cc89 CC=/opt/nvidia/hpc_sdk/Linux_x86_64/24.3/compilers/bin/nvc++",
      "clean": "make -f Makefile.nvc clean"
    },
    "variables": null,
    "outputs": {
      "executable": "main"
    }
  },
  "run": {
    "executable": "./main",
    "default_arguments": [
      "-n",
      "20000",
      "-i",
      "100"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "-n",
          "10000",
          "-i",
          "50"
        ],
        "description": "PageRank with 10000 nodes, 50 iterations for correctness validation (OMP target offload)",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      },
      "performance": {
        "arguments": [
          "-n",
          "20000",
          "-i",
          "100"
        ],
        "description": "PageRank with 20000 nodes, 100 iterations for performance measurement",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "stdout_pattern",
        "pattern": "PASS",
        "description": "OMP target PageRank results compared against CPU reference implementation"
      },
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly"
      }
    ],
    "floating_point": {
      "tolerance": 1e-06,
      "tolerance_type": "absolute",
      "note": "PageRank convergence comparison with tolerance threshold"
    }
  },
  "performance": {
    "metrics": [
      {
        "name": "kernel_time",
        "extraction": {
          "type": "regex",
          "pattern": "Total kernel execution time:\\s+([\\d.]+)\\s+\\(s\\)",
          "capture_group": 1
        },
        "unit": "seconds"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "gpu",
    "requirements": {
      "gpu": {
        "vendor": "NVIDIA",
        "min_compute_capability": "sm_60",
        "min_memory_gb": 2
      }
    },
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
      "gpu": {
        "model": "NVIDIA GeForce RTX 4070",
        "architecture": "Ada Lovelace",
        "compute_capability": "sm_89",
        "vram_gb": 12,
        "memory_bandwidth_gbps": 504,
        "cuda_cores": 5888
      },
      "cpu": {
        "model": "AMD Ryzen 9 7900X",
        "cores": 12,
        "threads": 24,
        "base_clock_ghz": 4.7
      },
      "software": {
        "os": "Ubuntu 22.04 LTS",
        "cuda_toolkit": "12.x",
        "gcc": "11+",
        "driver": "525.x+"
      }
    }
  },
  "baseline_results": {
    "reference_platform": "rtx4070-r9-7900x",
    "timestamp": "2026-03-28T23:15:00Z",
    "configurations": {
      "correctness": {
        "status": "pass",
        "exit_code": 0,
        "stdout_snippet": "Max difference 0.000004 is reached at iteration 51\n\"Options\": \"-n 10000 -i 50 -t 0.000000\". Total kernel execution time: 0.356104 (s)\nPASS",
        "wall_time_seconds": null
      }
    }
  },
  "metadata": {
    "description": "PageRank algorithm using OpenMP target offload with map and reduce kernels. Iteratively computes page rank scores with convergence checking. Depends on reference.h from page-rank-cuda directory.",
    "domain": "graph",
    "complexity": "O(V * E * iterations)",
    "tags": [
      "pagerank",
      "graph",
      "omp-target",
      "iterative",
      "map-reduce"
    ],
    "multi_file": false,
    "translation_complexity": null
  }
}
