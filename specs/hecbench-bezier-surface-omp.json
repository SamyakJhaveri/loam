{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "bezier-surface",
    "parallel_api": "omp",
    "unique_id": "hecbench-bezier-surface-omp",
    "source_suite": "hecbench"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/zjin-lcf/HeCBench",
      "commit": "archive-download",
      "branch": "master"
    },
    "repo_root": "HeCBench-master/",
    "source_path": "src/bezier-surface-omp",
    "license": "MIT"
  },
  "files": {
    "prompt_payload": [
      "main.cpp"
    ],
    "support_files": [
      "Makefile",
      "Makefile.aomp",
      "Makefile.nvc",
      "CMakeLists.txt",
      "input"
    ],
    "verification_only": []
  },
  "implementation": {
    "api": "omp",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++17"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "GCC >= 9.0 with OpenMP support"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/bezier-surface-omp",
    "commands": {
      "configure": null,
      "build": "make -f Makefile.aomp CC=g++ DEVICE=cpu",
      "clean": "make -f Makefile.aomp clean"
    },
    "variables": null,
    "outputs": {
      "executable": "bs"
    }
  },
  "run": {
    "executable": "./bs",
    "default_arguments": [
      "-n",
      "8192"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "-n",
          "256"
        ],
        "description": "Small surface (256) for correctness; element-wise comparison of GPU vs CPU Bezier output",
        "input_files": [
          "input/control.txt"
        ],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      },
      "performance": {
        "arguments": [
          "-n",
          "8192"
        ],
        "description": "Large surface (8192) for performance measurement",
        "input_files": [
          "input/control.txt"
        ],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "stdout_pattern",
        "pattern": "PASS",
        "description": "Element-wise comparison of GPU vs CPU Bezier surface points"
      },
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly"
      }
    ],
    "floating_point": {
      "tolerance": 0.001,
      "tolerance_type": "absolute",
      "note": "Element-wise absolute difference of surface point coordinates"
    }
  },
  "performance": {
    "metrics": [
      {
        "name": "kernel_time",
        "extraction": {
          "type": "regex",
          "pattern": "kernel execution time:\\s+([\\d.eE+-]+)\\s+ms",
          "capture_group": 1
        },
        "unit": "ms"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "cpu",
    "requirements": null,
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
      "gpu": {
        "model": "NVIDIA GeForce RTX 4070",
        "architecture": "Ada Lovelace",
        "compute_capability": "sm_89",
        "vram_gb": 12,
        "memory_bandwidth_gbps": 504,
        "cuda_cores": 5888
      },
      "cpu": {
        "model": "AMD Ryzen 9 7900X",
        "cores": 12,
        "threads": 24,
        "base_clock_ghz": 4.7
      },
      "software": {
        "os": "Ubuntu 22.04 LTS",
        "cuda_toolkit": "12.x",
        "gcc": "11+",
        "driver": "525.x+"
      }
    }
  },
  "baseline_results": {
    "reference_platform": "rtx4070-r9-7900x",
    "timestamp": "2026-03-03T18:52:35Z",
    "configurations": {
