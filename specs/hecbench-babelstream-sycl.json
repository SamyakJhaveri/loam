{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "babelstream",
    "parallel_api": "sycl",
    "unique_id": "hecbench-babelstream-sycl",
    "source_suite": "hecbench"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/zjin-lcf/HeCBench",
      "commit": "archive-download",
      "branch": "master"
    },
    "repo_root": "HeCBench-master/",
    "source_path": "src/babelstream-sycl",
    "license": "MIT"
  },
  "files": {
    "prompt_payload": [
      "main.cpp"
    ],
    "support_files": [
      "Makefile",
      "CMakeLists.txt"
    ],
    "verification_only": []
  },
  "implementation": {
    "api": "sycl",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++17"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "Intel oneAPI DPC++/C++ Compiler",
          "GCC >= 9.0"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/babelstream-sycl",
    "commands": {
      "configure": null,
      "build": "make",
      "clean": "make clean"
    },
    "variables": null,
    "outputs": {
      "executable": "main"
    }
  },
  "run": {
    "executable": "./main",
    "default_arguments": [],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [],
        "description": "Default BabelStream run with internal validation of Copy/Mul/Add/Triad/Dot/Nstream",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "Function"
        }
      },
      "performance": {
        "arguments": [],
        "description": "Default run; reports bandwidth in MBytes/sec for each kernel",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "Function"
        }
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "stdout_pattern",
        "pattern": "Function",
        "description": "Output includes Function/MBytes/sec table header, indicating successful kernel execution"
      },
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly; internal validation aborts on error"
      }
    ],
    "floating_point": null
  },
  "performance": {
    "metrics": [
      {
        "name": "triad_bandwidth",
        "extraction": {
          "type": "regex",
          "pattern": "Triad\\s+([\\d.eE+-]+)",
          "capture_group": 1
        },
        "unit": "MB/s"
      },
      {
        "name": "copy_bandwidth",
        "extraction": {
          "type": "regex",
          "pattern": "Copy\\s+([\\d.eE+-]+)",
          "capture_group": 1
        },
        "unit": "MB/s"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "gpu",
    "requirements": {
      "gpu": {
        "vendor": "NVIDIA",
        "min_compute_capability": "sm_60",
        "min_memory_gb": 2
      }
    },
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
      "gpu": {
        "model": "NVIDIA GeForce RTX 4070",
        "architecture": "Ada Lovelace",
        "compute_capability": "sm_89",
        "vram_gb": 12,
        "memory_bandwidth_gbps": 504,
        "cuda_cores": 5888
      },
      "cpu": {
        "model": "AMD Ryzen 9 7900X",
        "cores": 12,
        "threads": 24,
        "base_clock_ghz": 4.7
      },
      "software": {
        "os": "Ubuntu 22.04 LTS",
        "cuda_toolkit": "12.x",
        "gcc": "11+",
        "driver": "525.x+"
      }
    }
  },
  "baseline_results": null,
  "metadata": {
    "description": "BabelStream memory bandwidth benchmark. Measures achievable memory bandwidth using Copy, Mul, Add, Triad, Dot, and Nstream kernels. Based on the STREAM benchmark methodology.",
    "domain": "memory bandwidth",
    "complexity": "O(n)",
    "tags": [
      "babelstream",
      "stream",
      "memory-bandwidth",
      "benchmark",
      "copy",
      "triad",
      "dot-product"
    ],
    "multi_file": false
  }
}
