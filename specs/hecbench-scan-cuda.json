{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "scan",
    "parallel_api": "cuda",
    "unique_id": "hecbench-scan-cuda",
    "source_suite": "hecbench"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/zjin-lcf/HeCBench",
      "commit": "archive-download",
      "branch": "master"
    },
