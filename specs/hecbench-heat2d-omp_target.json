{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "heat2d",
    "parallel_api": "omp_target",
    "unique_id": "hecbench-heat2d-omp_target",
    "source_suite": "hecbench"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/zjin-lcf/HeCBench",
      "commit": "22785cdd708de5dca56525a277b31fe119171fd1",
      "branch": "master"
    },
    "repo_root": "HeCBench-master/",
    "source_path": "src/heat2d-omp",
    "license": "MIT"
  },
  "files": {
    "prompt_payload": [
      "main.cpp"
    ],
    "support_files": [
      "Makefile",
      "Makefile.nvc",
      "Makefile.aomp",
      "CMakeLists.txt",
      "README"
    ],
    "verification_only": [],
    "translation_targets": [
      "main.cpp"
    ]
  },
  "implementation": {
    "api": "omp_target",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++14"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "nvidia-hpc-sdk (nvc++ with OpenMP target offload)"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/heat2d-omp",
    "commands": {
      "configure": null,
      "build": "make -f Makefile.nvc SM=cc89 CC=/opt/nvidia/hpc_sdk/Linux_x86_64/24.3/compilers/bin/nvc++",
      "clean": "make -f Makefile.nvc clean"
    },
    "variables": null,
    "outputs": {
      "executable": "main"
    }
  },
  "run": {
    "executable": "./main",
    "default_arguments": [
      "1024",
      "1024",
      "100"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "1024",
          "1024",
          "100"
        ],
        "description": "2D heat equation on 1024x1024 grid, 100 iterations for correctness validation (OMP target offload)",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      },
      "performance": {
        "arguments": [
          "4096",
          "4096",
          "1000"
        ],
        "description": "2D heat equation on 4096x4096 grid, 1000 iterations for performance measurement",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "stdout_pattern",
        "pattern": "PASS",
        "description": "GPU Laplacian result compared against CPU reference with periodic boundary conditions"
      },
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly"
      }
    ],
    "floating_point": {
      "tolerance": 1e-06,
      "tolerance_type": "absolute",
      "note": "Floating-point comparison of 2D heat equation results"
    }
  },
  "performance": {
    "metrics": [
      {
        "name": "throughput",
        "extraction": {
          "type": "regex",
          "pattern": "BW =\\s+([\\d.]+)\\s+GB/s",
          "capture_group": 1
        },
        "unit": "GB/s"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "gpu",
    "requirements": {
      "gpu": {
        "vendor": "NVIDIA",
        "min_compute_capability": "sm_60",
        "min_memory_gb": 2
      }
    },
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
      "gpu": {
        "model": "NVIDIA GeForce RTX 4070",
        "architecture": "Ada Lovelace",
        "compute_capability": "sm_89",
        "vram_gb": 12,
        "memory_bandwidth_gbps": 504,
        "cuda_cores": 5888
      },
      "cpu": {
        "model": "AMD Ryzen 9 7900X",
        "cores": 12,
        "threads": 24,
        "base_clock_ghz": 4.7
      },
      "software": {
        "os": "Ubuntu 22.04 LTS",
        "cuda_toolkit": "12.x",
        "gcc": "11+",
        "driver": "525.x+"
      }
    }
  },
  "baseline_results": {
    "reference_platform": "rtx4070-r9-7900x",
    "timestamp": "2026-03-28T23:15:00Z",
    "configurations": {
      "correctness": {
        "status": "pass",
        "exit_code": 0,
        "stdout_snippet": "Ly,Lx = 1024,1024\n niter = 100\nDevice: iters =      100, (Lx,Ly) =   1024,   1024, t =    355.3 usec/iter, BW = 23.612 GB/s, P = 17.709 Gflop/s\nPASS",
        "wall_time_seconds": null
      }
    }
  },
  "metadata": {
    "description": "2D heat equation (Laplacian) solver using OpenMP target offload. Periodic boundary conditions with 5-point stencil, verified against CPU reference.",
    "domain": "stencil computation",
    "complexity": "O(Lx * Ly * niter)",
    "tags": [
      "heat-equation",
      "laplacian",
      "omp-target",
      "stencil",
      "2d",
      "periodic-bc"
    ],
    "multi_file": false,
    "translation_complexity": null
  }
}
