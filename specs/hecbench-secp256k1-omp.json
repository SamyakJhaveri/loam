  "implementation": {
    "api": "omp",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++17"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "GCC >= 9.0 with OpenMP support"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/secp256k1-omp",
    "commands": {
      "configure": null,
