                    "stdout_pattern": "CSV data"
                }
            },
            "performance": {
                "arguments": [],
                "description": "Default run for performance measurement of mixbench (OpenCL)",
                "input_files": [],
                "expected_results": {
                    "stdout_pattern": "CSV data"
                }
            }
        }
    },
    "verification": {
        "method": "self_checking",
        "strategies": [
            {
                "type": "stdout_pattern",
                "pattern": "CSV data",
