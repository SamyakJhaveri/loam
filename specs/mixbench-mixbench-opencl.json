                "extraction": {
                    "type": "regex",
                    "pattern": "\\s+0,\\s+\\d+\\.\\d+,\\s+\\d+\\.\\d+,\\s+([\\d.]+),\\s+[\\d.]+,",
                    "capture_group": 1
                },
                "unit": "GFLOPS"
