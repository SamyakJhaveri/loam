{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "md",
    "parallel_api": "omp_target",
    "unique_id": "hecbench-md-omp_target",
    "source_suite": "hecbench"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/zjin-lcf/HeCBench",
      "commit": "archive-download",
      "branch": "master"
    },
    "repo_root": "HeCBench-master/",
    "source_path": "src/md-omp",
    "license": "MIT"
  },
  "files": {
    "prompt_payload": [
      "main.cpp"
    ],
    "support_files": [
      "Makefile",
      "Makefile.nvc",
      "Makefile.aomp",
      "CMakeLists.txt",
      "MD.h",
      "LICENSE"
    ],
    "verification_only": [],
    "translation_targets": [
      "main.cpp"
    ]
  },
  "implementation": {
    "api": "omp_target",
    "api_version": "OpenMP 4.5+",
    "language": "C++",
    "language_standard": "C++14"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "NVIDIA HPC SDK >= 24.0 (nvc++)",
          "OpenMP target offload support"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/md-omp",
    "commands": {
      "configure": null,
      "build": "make -f Makefile.nvc SM=cc89 CC=/opt/nvidia/hpc_sdk/Linux_x86_64/24.3/compilers/bin/nvc++",
      "clean": "make -f Makefile.nvc clean"
    },
    "variables": null,
    "outputs": {
      "executable": "main"
    }
  },
  "run": {
    "executable": "./main",
    "default_arguments": [
      "1",
      "100"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "1",
          "100"
        ],
        "description": "Molecular dynamics with class_size=1 (24576 atoms), 100 iterations; verifies GPU vs CPU force calculation",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "Max error between host and device"
        }
      },
      "performance": {
        "arguments": [
          "1",
          "100"
        ],
        "description": "Same config for timing measurement",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "Max error between host and device"
        }
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "stdout_pattern",
        "pattern": "Max error between host and device:\\s+([+-]?\\d[\\d.eE+-]*)",
        "description": "CPU reference force calculation compared to GPU; prints max error with numeric value (tightened from bare literal per S3 audit bucket2 option (d))"
      },
      {
        "type": "numeric_comparison",
        "extract_regex": "Max error between host and device:\\s+([+-]?\\d[\\d.eE+-]*)",
        "expected": 0.0,
        "tolerance": 1e-09,
        "description": "Molecular dynamics host-vs-device force calculation max-error vs baseline 0.0 (omp_target). Policy B-per-spec tolerance 1e-9 absolute (~1 ppb \u2014 semantically 'max error below 1 ppb'). Added 2026-04-19 (S7c): bucket2 mis-label \u2192 medium numeric_comparison oracle."
      },
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly"
      }
    ],
    "floating_point": null,
    "oracle_strength": "medium"
  },
  "performance": {
    "metrics": [
      {
        "name": "kernel_time",
        "extraction": {
          "type": "regex",
          "pattern": "Average kernel execution time\\s+([\\d.eE+-]+)\\s+\\(s\\)",
          "capture_group": 1
        },
        "unit": "s"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "gpu",
    "requirements": {
      "gpu": {
        "vendor": "NVIDIA",
        "min_compute_capability": "sm_60",
        "min_memory_gb": 2
      }
    },
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
      "gpu": {
        "model": "NVIDIA GeForce RTX 4070",
        "architecture": "Ada Lovelace",
        "compute_capability": "sm_89",
        "vram_gb": 12,
        "memory_bandwidth_gbps": 504,
        "cuda_cores": 5888
      },
      "cpu": {
        "model": "AMD Ryzen 9 7900X",
        "cores": 12,
        "threads": 24,
        "base_clock_ghz": 4.7
      },
      "software": {
        "os": "Ubuntu 22.04 LTS",
        "cuda_toolkit": "12.x",
        "gcc": "11+",
        "driver": "525.x+"
      }
    }
  },
  "baseline_results": {
    "reference_platform": "rtx4070-r9-7900x",
    "timestamp": "2026-03-28T20:00:00Z",
    "configurations": {
      "correctness": {
        "status": "pass",
        "exit_code": 0,
        "stdout_snippet": "Max error between host and device: 0\nAverage kernel execution time 0.00445281 (s)",
        "wall_time_seconds": null
      },
      "performance": {
        "status": "pass",
        "wall_time_seconds": null,
        "metrics": {
          "kernel_time_s": 0.00445281
        }
      }
    }
  },
  "metadata": {
    "description": "Lennard-Jones molecular dynamics force calculation using OpenMP target offload to GPU. Computes pairwise forces using neighbor lists with cutoff distance, verified against CPU reference.",
    "domain": "molecular dynamics",
    "complexity": "O(N x maxNeighbors)",
    "tags": [
      "molecular-dynamics",
      "lennard-jones",
      "force-calculation",
      "neighbor-list",
      "pairwise",
      "omp-target"
    ],
    "multi_file": false,
    "translation_complexity": null
  }
}
