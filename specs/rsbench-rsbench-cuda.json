{
    "spec_version": "1.0.0",
    "identity": {
        "kernel_name": "rsbench",
        "parallel_api": "cuda",
        "unique_id": "rsbench-rsbench-cuda",
        "source_suite": "rsbench"
    },
    "provenance": {
        "repository": {
            "url": "https://github.com/ANL-CESAR/RSBench",
            "commit": "34b644787ea9af4fb188e1253da72e09bbed9989",
            "branch": "master"
        },
        "repo_root": "rsbench/rsbench-src",
        "source_path": "cuda",
        "license": "MIT"
    },
    "files": {
        "prompt_payload": [
            "main.cu",
            "io.cu",
            "simulation.cu",
            "init.cu",
            "material.cu",
            "utils.cu"
        ],
        "support_files": [
            "Makefile",
            "rsbench.cuh"
        ],
        "verification_only": [],
        "translation_targets": [
            "main.cu",
            "io.cu",
            "simulation.cu",
            "init.cu",
            "material.cu",
            "utils.cu"
        ]
    },
    "implementation": {
        "api": "cuda",
        "api_version": null,
        "language": "C++",
        "language_standard": "C++14"
    },
    "build": {
        "environment": {
            "preferred": "system",
            "conda": null,
            "system": {
                "dependencies": [
                    "cuda-toolkit>=11.0",
                    "gcc>=9.0"
                ]
            }
        },
        "build_system": "make",
        "working_directory": "cuda",
        "commands": {
            "configure": null,
            "build": "make SM_VERSION=89",
            "clean": "make clean"
        },
        "variables": {
            "SM_VERSION": {
                "description": "CUDA compute capability without sm_ prefix (89 for RTX 4070)",
                "default": "89",
                "detection": "nvidia-smi --query-gpu=compute_cap --format=csv,noheader | head -1 | tr -d '.'"
            }
        },
        "outputs": {
            "executable": "./rsbench"
        }
    },
    "run": {
        "executable": "./rsbench",
        "default_arguments": [
            "-m",
            "event",
            "-s",
            "small"
        ],
        "timeout_seconds": 300,
        "environment_variables": null,
        "input_configurations": {
            "correctness": {
                "arguments": [
                    "-m",
                    "event",
                    "-s",
                    "small"
                ],
                "description": "Small event-based input for correctness verification of rsbench (CUDA)",
                "input_files": [],
                "expected_results": {
                    "stdout_pattern": "Verification checksum: \\d+ \\(Valid\\)"
                }
            },
            "performance": {
                "arguments": [
                    "-m",
                    "event",
                    "-s",
                    "large"
                ],
                "description": "Large event-based input for performance measurement of rsbench (CUDA)",
                "input_files": [],
                "expected_results": {
                    "stdout_pattern": "Verification checksum: \\d+ \\(Valid\\)"
                }
            }
        }
    },
    "verification": {
        "method": "self_checking",
        "strategies": [
            {
                "type": "stdout_pattern",
                "pattern": "Verification checksum: \\d+ \\(Valid\\)",
                "description": "RSBench self-verification reports valid checksum"
            },
            {
                "type": "exit_code",
                "expected": 0,
                "description": "Process exits with code 0 on valid checksum, 1 on invalid"
            }
        ],
        "floating_point": null
    },
    "performance": {
        "metrics": [
            {
                "name": "runtime",
                "extraction": {
                    "type": "regex",
                    "pattern": "Runtime:\\s+([\\d.]+)\\s+seconds",
                    "capture_group": 1
                },
                "unit": "seconds"
            },
            {
                "name": "lookups_per_second",
                "extraction": {
                    "type": "regex",
                    "pattern": "Lookups/s:\\s+([\\d,]+)",
                    "capture_group": 1
                },
                "unit": "lookups/s"
            }
        ],
        "warmup_runs": 0,
        "measurement_runs": 1
    },
    "hardware": {
        "target": "gpu",
        "requirements": {
            "gpu": {
                "vendor": "NVIDIA",
                "min_compute_capability": "sm_60",
                "min_memory_gb": 4
            }
        },
        "reference_platform": {
            "platform_id": "rtx4070-linux-x86_64",
            "gpu": {
                "model": "NVIDIA GeForce RTX 4070",
                "architecture": "Ada Lovelace",
                "compute_capability": "sm_89",
                "vram_gb": 12,
                "memory_bandwidth_gbps": 504,
                "cuda_cores": 5888
            },
            "cpu": {
                "model": "AMD Ryzen 9 7900X",
                "cores": 12,
                "threads": 24,
                "base_clock_ghz": 4.7
            },
            "software": {
                "os": "Ubuntu 22.04 LTS",
                "cuda_toolkit": "12.x",
                "gcc": "11+",
                "driver": "525.x+"
            }
        }
    },
    "baseline_results": {
        "reference_platform": "rtx4070-linux-x86_64",
        "timestamp": "2026-03-28T20:00:00+00:00",
        "configurations": {
            "correctness": {
                "status": "pass",
                "exit_code": 0,
                "stdout_snippet": "Programming Model:           CUDA\nCUDA Device:                 NVIDIA GeForce RTX 4070\nSimulation Method:           Event Based\nH-M Benchmark Size:          Small\nTotal XS Lookups:            10,200,000\nRuntime:               2.533 seconds\nLookups:               10,200,000\nLookups/s:             4,026,270\nVerification checksum: 880018 (Valid)\n",
                "wall_time_seconds": 2.6,
                "metrics": {}
            }
        }
    },
    "metadata": {
        "description": "Monte Carlo multipole resolved resonance cross-section lookup (RSBench)",
        "domain": "nuclear physics",
        "complexity": "Monte Carlo cross-section lookup with multipole resonance method",
        "tags": [
            "cuda",
            "monte-carlo",
            "nuclear",
            "physics",
            "rsbench"
        ],
        "multi_file": true,
        "translation_complexity": null
    }
}
