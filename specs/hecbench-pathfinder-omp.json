  "metadata": {
    "description": "Dynamic-programming pathfinder on a 2D grid. Finds minimum cost path from top row to bottom row using parallel wavefront propagation.",
    "domain": "dynamic programming",
    "complexity": "O(rows \u00d7 cols)",
    "tags": [
