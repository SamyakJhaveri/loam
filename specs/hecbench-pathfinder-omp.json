{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "pathfinder",
    "parallel_api": "omp",
    "unique_id": "hecbench-pathfinder-omp",
    "source_suite": "hecbench"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/zjin-lcf/HeCBench",
      "commit": "archive-download",
      "branch": "master"
    },
    "repo_root": "HeCBench-master/",
    "source_path": "src/pathfinder-omp",
    "license": "MIT"
  },
  "files": {
    "prompt_payload": [
      "main.cpp"
    ],
    "support_files": [
      "Makefile",
      "Makefile.aomp",
      "Makefile.nvc",
      "CMakeLists.txt"
    ],
    "verification_only": []
  },
  "implementation": {
    "api": "omp",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++17"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "GCC >= 9.0 with OpenMP support"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/pathfinder-omp",
    "commands": {
      "configure": null,
      "build": "make -f Makefile.aomp CC=g++ DEVICE=cpu",
      "clean": "make -f Makefile.aomp clean"
    },
    "variables": null,
    "outputs": {
      "executable": "main"
    }
  },
  "run": {
    "executable": "./main",
    "default_arguments": [
      "100000",
      "1000",
      "5"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "100",
          "10",
          "5"
        ],
        "description": "Small grid (100\u00d710) for quick correctness run",
        "input_files": [],
        "expected_results": null
      },
      "performance": {
        "arguments": [
          "100000",
          "1000",
          "5"
        ],
        "description": "Large grid (100000\u00d71000) for performance measurement",
        "input_files": [],
        "expected_results": null
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly with code 0"
      },
      {
        "type": "stdout_pattern",
        "pattern": "Total kernel execution time",
        "description": "Timing output confirms successful computation"
      }
    ],
    "floating_point": null
  },
  "performance": {
    "metrics": [
      {
        "name": "kernel_time",
        "extraction": {
          "type": "regex",
          "pattern": "Total kernel execution time:\\s+([\\d.eE+-]+)\\s+\\(s\\)",
          "capture_group": 1
        },
        "unit": "s"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "cpu",
    "requirements": null,
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
