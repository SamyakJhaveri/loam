{
  "spec_version": "1.0.0",
  "identity": {
    "kernel_name": "radixsort",
    "parallel_api": "omp",
    "unique_id": "hecbench-radixsort-omp",
    "source_suite": "hecbench"
  },
  "provenance": {
    "repository": {
      "url": "https://github.com/zjin-lcf/HeCBench",
      "commit": "archive-download",
      "branch": "master"
    },
    "repo_root": "HeCBench-master/",
    "source_path": "src/radixsort-omp",
    "license": "MIT"
  },
  "files": {
    "prompt_payload": [
      "main.cpp",
      "RadixSort.cpp",
      "RadixSort_kernels.cpp",
      "Scan.cpp",
      "Scan_kernels.cpp"
    ],
    "support_files": [
      "Makefile",
      "Makefile.aomp",
      "Makefile.nvc",
      "CMakeLists.txt",
      "RadixSort.h",
      "Scan.h"
    ],
    "verification_only": []
  },
  "implementation": {
    "api": "omp",
    "api_version": null,
    "language": "C++",
    "language_standard": "C++17"
  },
  "build": {
    "environment": {
      "preferred": "system",
      "conda": null,
      "system": {
        "dependencies": [
          "GCC >= 9.0"
        ]
      }
    },
    "build_system": "make",
    "working_directory": "src/radixsort-omp",
    "commands": {
      "configure": null,
      "build": "make -f Makefile.aomp CC=g++ DEVICE=cpu DEBUG=no",
      "clean": "make -f Makefile.aomp clean"
    },
    "variables": null,
    "outputs": {
      "executable": "main"
    }
  },
  "run": {
    "executable": "./main",
    "default_arguments": [
      "1000"
    ],
    "timeout_seconds": 300,
    "environment_variables": null,
    "input_configurations": {
      "correctness": {
        "arguments": [
          "1"
        ],
        "description": "Single iteration for correctness validation (sorts 4M uint32 elements)",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      },
      "performance": {
        "arguments": [
          "1000"
        ],
        "description": "1000 iterations for performance measurement",
        "input_files": [],
        "expected_results": {
          "stdout_pattern": "PASS"
        }
      }
    }
  },
  "verification": {
    "method": "self_checking",
    "strategies": [
      {
        "type": "stdout_pattern",
        "pattern": "PASS",
        "description": "Verifies sorted array is monotonically non-decreasing. Checked first because exit_code=0 even when sort is wrong."
      },
      {
        "type": "exit_code",
        "expected": 0,
        "description": "Process exits cleanly"
      }
    ],
    "floating_point": null
  },
  "performance": {
    "metrics": [
      {
        "name": "sort_time",
        "extraction": {
          "type": "regex",
          "pattern": "Average execution time of radixsort:\\s+([\\d.]+)\\s+\\(s\\)",
          "capture_group": 1
        },
        "unit": "s"
      }
    ],
    "warmup_runs": 1,
    "measurement_runs": 5
  },
  "hardware": {
    "target": "cpu",
    "requirements": {
      "cpu": {
        "min_cores": 4,
        "min_memory_gb": 4
      }
    },
    "reference_platform": {
      "platform_id": "rtx4070-r9-7900x",
      "gpu": {
        "model": "NVIDIA GeForce RTX 4070",
        "architecture": "Ada Lovelace",
        "compute_capability": "sm_89",
        "vram_gb": 12,
        "memory_bandwidth_gbps": 504,
        "cuda_cores": 5888
      },
      "cpu": {
        "model": "AMD Ryzen 9 7900X",
        "cores": 12,
        "threads": 24,
        "base_clock_ghz": 4.7
      },
      "software": {
        "os": "Ubuntu 22.04 LTS",
        "cuda_toolkit": "12.x",
        "gcc": "11+",
        "driver": "525.x+"
      }
    }
  },
  "baseline_results": {
    "reference_platform": "rtx4070-r9-7900x",
    "timestamp": "2026-02-11T12:00:00Z",
    "configurations": {
      "correctness": {
        "status": "fail",
        "exit_code": 139,
        "stdout_snippet": "Segmentation fault (core dumped)",
        "wall_time_seconds": null,
        "fail_reason": "SEGFAULT (signal 11). Root cause: warp-level scan functions (scanwarp in RadixSort_kernels.cpp, warpScanInclusive in Scan_kernels.cpp) rely on GPU lockstep execution within 32-thread warps and omit #pragma omp barrier. On CPU with >=2 threads, concurrent threads race on shared sData/l_Data arrays, producing corrupted rank values that become out-of-bounds indices into team-private sMem arrays. Additionally, kernels assume omp_get_num_threads()==CTA_SIZE (128) via thread_limit clause, but CPU runtime caps at nproc (24 on test machine). With 1 thread: no crash but FAIL (algorithm produces wrong results). With 2+ threads: SEGFAULT. This is an inherent GPU-to-CPU portability defect in the benchmark source.",
        "fail_category": "benchmark_source_gpu_assumption",
        "reproducibility": "deterministic"
      }
    }
  },
  "metadata": {
    "description": "Parallel radix sort (Satish-Harris-Garland) for unsigned 32-bit integers. 4-bit radix (16 buckets), 8 passes, with block-level sort, offset finding, prefix scan, and global reorder kernels.",
    "domain": "parallel sorting",
    "complexity": "O(n \u00d7 passes)",
    "tags": [
      "radix-sort",
      "sorting",
      "parallel-primitives",
      "prefix-scan"
    ],
    "multi_file": true
  }
}
