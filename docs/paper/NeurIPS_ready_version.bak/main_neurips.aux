\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Benchmark kernel richness (y-axis, capped at 100 for readability) vs.\ API breadth (x-axis, number of APIs supported). Bubble size proportional to total kernel count; color indicates benchmark type. HeCBench (516 kernels, 4\nobreakspace  {}APIs) dominates the upper region. RAJAPerf (80 kernels, 5\nobreakspace  {}APIs) is the second-largest. CloverLeaf (23 kernels, 9\nobreakspace  {}APIs) and BabelStream (5 kernels, 12\nobreakspace  {}APIs) occupy the high-API-breadth region but with far fewer kernels. The optimal candidates for corpus construction lie in the high-kernel, moderate-API quadrant (upper-center).}}{19}{figure.9}\protected@file@percent }
\newlabel{fig:kernel-api-bubble}{{9}{19}{Benchmark kernel richness (y-axis, capped at 100 for readability) vs.\^^MAPI breadth (x-axis, number of APIs supported). Bubble size proportional to total kernel count; color indicates benchmark type. HeCBench (516 kernels, 4~APIs) dominates the upper region. RAJAPerf (80 kernels, 5~APIs) is the second-largest. CloverLeaf (23 kernels, 9~APIs) and BabelStream (5 kernels, 12~APIs) occupy the high-API-breadth region but with far fewer kernels. The optimal candidates for corpus construction lie in the high-kernel, moderate-API quadrant (upper-center)}{figure.9}{}}
\citation{Rodinia2009}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Top ``Rosetta Stone'' candidates ranked by kernel count (blue bars, scaled for readability; true counts annotated above) and API breadth (red bars). HeCBench provides the largest kernel pool (516 kernels) but with only\nobreakspace  {}4 primary APIs (CUDA, HIP, SYCL, OpenMP). BabelStream provides the broadest API coverage (12\nobreakspace  {}APIs) but with only 5\nobreakspace  {}kernels. RAJAPerf (80 kernels, 7\nobreakspace  {}APIs) offers a balanced middle ground. Rodinia (24 kernels, 3 primary APIs) provides established, well-understood benchmarks with strong community recognition.}}{20}{figure.10}\protected@file@percent }
\newlabel{fig:top-candidates}{{10}{20}{Top ``Rosetta Stone'' candidates ranked by kernel count (blue bars, scaled for readability; true counts annotated above) and API breadth (red bars). HeCBench provides the largest kernel pool (516 kernels) but with only~4 primary APIs (CUDA, HIP, SYCL, OpenMP). BabelStream provides the broadest API coverage (12~APIs) but with only 5~kernels. RAJAPerf (80 kernels, 7~APIs) offers a balanced middle ground. Rodinia (24 kernels, 3 primary APIs) provides established, well-understood benchmarks with strong community recognition}{figure.10}{}}
