\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces API co-occurrence heatmap across all 71 surveyed repositories. Cell values indicate the number of repositories providing implementations in both the row and column APIs.}}{21}{figure.3}\protected@file@percent }
