{
  "_comment": "{{ project_name }} MCP servers. Graphify and the Knowledge-Graph Memory server ship enabled. CodeBurn and Superpowers are plugins installed via /plugin marketplace add — see docs/MEMORY.md.",
  "mcpServers": {
    "graphify": {
      "type": "stdio",
      "command": "python3",
      "args": ["-m", "graphify.serve", "graphify-out/graph.json"]
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "${PWD}/.claude-memory/knowledge-graph.json"
      }
    }
  }
}
