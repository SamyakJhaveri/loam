{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-tool-policy.py\"",
            "timeout": 10,
            "statusMessage": "Checking Codex tool policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/post-tool-policy.py\"",
            "timeout": 10,
            "statusMessage": "Running Codex post-tool checks"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/post-compact-recovery.sh\"",
            "timeout": 10,
            "statusMessage": "Recovering compacted context"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/session-start.sh\"",
            "timeout": 5,
            "statusMessage": "Loading session notes"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-verify-gate.sh\"",
            "timeout": 30,
            "statusMessage": "Running turn-end verification"
          }
        ]
      }
    ]
  }
}
