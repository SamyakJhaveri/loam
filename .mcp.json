{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "disabled": true
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "disabled": true
    },
    "css-docs": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@stolinski/css-mcp"
      ],
      "env": {},
      "disabled": true
    }
  }
}
